# SQLite database file path for Prisma.
# На проде: file:/var/www/fastlanes/fastlanes.db (задаётся через Ansible env.j2)
DATABASE_URL="file:./fastlanes.db"

# Auth.js (NextAuth) — JWT-сессии, без БД-таблицы для сессий.
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Сидинг первого администратора. Прочитываются `npm run db:seed`
# и применяются ТОЛЬКО если в БД нет ни одного пользователя с ролью admin.
# В проде задаются через ansible-vault (vault_admin_initial_*).
ADMIN_INITIAL_EMAIL=""
ADMIN_INITIAL_PASSWORD=""
ADMIN_INITIAL_NAME="Admin"
