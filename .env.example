# PostgreSQL connection string for Prisma.
# Локально: postgres://postgres:postgres@localhost:5432/fastlanes
# На проде Ansible создаёт пользователя fastlanes и БД fastlanes.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastlanes?schema=public"

# Auth.js (NextAuth) — заполнится на этапе 3.
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Окружение
NODE_ENV="development"
