DATABASE_URL="file:{{ app_dir }}/fastlanes.db"
AUTH_SECRET="{{ auth_secret }}"
AUTH_URL="https://{{ domain }}"
NODE_ENV="production"

# Используются плейбуком ansible/bootstrap-admin.yml (запуск через
# workflow_dispatch). При обычном деплое не читаются.
ADMIN_INITIAL_EMAIL="{{ admin_initial_email | default('') }}"
ADMIN_INITIAL_PASSWORD="{{ admin_initial_password | default('') }}"
ADMIN_INITIAL_NAME="{{ admin_initial_name | default('Admin') }}"
